# ============================================
# VIBE PANEL - Configuration Environnement
# ============================================
# Copie ce fichier vers .env et remplis les valeurs

# ────────────────────────────────────────────
# SPOTIFY INTEGRATION (Optionnel)
# ────────────────────────────────────────────
# Créer une app sur: https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://localhost:5000/api/spotify/callback

# ────────────────────────────────────────────
# GOOGLE HOME (Optionnel)
# ────────────────────────────────────────────
# Pour l'intégration domotique
VITE_GOOGLE_CLIENT_ID=

# ────────────────────────────────────────────
# DISCORD BOT (Requis pour le bot)
# ────────────────────────────────────────────
# Token depuis: https://discord.com/developers/applications
# Active les Privileged Gateway Intents dans le Developer Portal
DISCORD_BOT_TOKEN=

# URL du Webhook Discord pour envoyer des messages
DISCORD_WEBHOOK_URL=

# ────────────────────────────────────────────
# PANEL CONFIGURATION
# ────────────────────────────────────────────
# URL publique du panel (pour le bot Discord)
PANEL_URL=http://localhost:5000

# ────────────────────────────────────────────
# GEMINI AI (Optionnel - Lumy fonctionne sans)
# ────────────────────────────────────────────
GEMINI_API_KEY=

# ────────────────────────────────────────────
# ZIMAOS MONITORING
# ────────────────────────────────────────────
# IP de ton serveur ZimaOS (défaut: 192.168.1.25)
# Peut être modifié directement dans l'interface
ZIMAOS_IP=192.168.1.25
